{
  "name": "dodge-rush-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Android (Expo) wrapper that ships the Dodge Rush web build offline inside a WebView.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "sync:web": "node scripts/sync-web.mjs",
    "prebuild": "expo prebuild --platform android --clean",
    "android": "expo run:android",
    "start": "expo start --dev-client",
    "doctor": "npx expo-doctor"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-keep-awake": "~14.0.1",
    "expo-screen-orientation": "~8.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-webview": "13.12.5"
  },
  "devDependencies": {
    "@expo/config-plugins": "~9.0.0",
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  }
}
