{
  "name": "dodge-rush",
  "version": "0.0.6",
  "description": "Dodge Rush — a retro cute pixel-art infinite faller built with Phaser 3 + TypeScript + Vite.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "playwright:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.19.43",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vitest": "^1.6.1"
  }
}
