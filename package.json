{
  "name": "dodge-rush",
  "version": "1.0.0",
  "description": "Dodge Rush — a retro cute pixel-art infinite faller built with Phaser 3 + TypeScript + Vite.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vitest": "^1.6.1"
  }
}
